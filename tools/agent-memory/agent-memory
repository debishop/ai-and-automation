<!-- Format: [YYYY-MM-DD] — Piece → Pillar · Stage · Word count/format · Source brief from Researcher · Fact-Check status · Open edits · Handoff -->
TEMPLATE
      ;;
    fact-checker|checker)
      cat > "$MEMORY_FILE" <<'TEMPLATE'
