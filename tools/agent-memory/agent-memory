  esac

  echo "Initialized $MEMORY_FILE for role: $role" >&2
}

case "$cmd" in
  read)    cmd_read "$@" ;;
  append)  cmd_append "$@" ;;
  compact) cmd_compact "$@" ;;
  init)    cmd_init "$@" ;;
  version|--version|-V) echo "agent-memory $AGENT_MEMORY_VERSION" ;;
  ""|--help|-h) usage ;;
  *) echo "Unknown command: $cmd" >&2; usage ;;
esac
